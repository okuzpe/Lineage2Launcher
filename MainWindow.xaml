<Window x:Class="Lineage2Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Lineage2Launcher.ViewModels"
        mc:Ignorable="d"
        Title="Lineage 2 Launcher - L2Titan" 
        Height="680" 
        Width="1024"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize">
    <Window.Resources>
        <vm:MainViewModel x:Key="ViewModel"/>
    </Window.Resources>
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.4"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
    
    <Border Style="{StaticResource WindowFrameStyle}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <!-- Left Column: Servers -->
            <Border Grid.Column="0" 
                    Background="{StaticResource MetallicGrayBrush}"
                    BorderBrush="{StaticResource OldGoldBrush}"
                    BorderThickness="0,0,2,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0"
                               Text="SERVERS"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{StaticResource OldGoldBrush}"
                               HorizontalAlignment="Center"
                               Margin="10"/>
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Servers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ServerItemStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <Ellipse Grid.Column="0"
                                                     Width="10" Height="10"
                                                     Fill="{Binding StatusBrush}"
                                                     Margin="0,0,10,0"
                                                     VerticalAlignment="Center"/>
                                            
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Name}"
                                                       Foreground="{StaticResource TextOnDarkBrush}"
                                                       VerticalAlignment="Center"/>
                                            
                                            <Button Grid.Column="2"
                                                    Content="★"
                                                    FontSize="12"
                                                    Width="25" Height="25"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Command="{Binding ToggleFavoriteCommand}">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Foreground" Value="{StaticResource MediumGrayBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource OldGoldBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Center Column: News -->
            <Border Grid.Column="1"
                    Background="{StaticResource PrimaryBlackBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0"
                               Text="NEWS"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{StaticResource OldGoldBrush}"
                               HorizontalAlignment="Center"
                               Margin="10"/>
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding News}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource NewsItemStyle}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Date, StringFormat='{}{0:dd/MM/yyyy}'}"
                                                       Foreground="{StaticResource MediumGrayBrush}"
                                                       FontSize="10"
                                                       Margin="0,0,0,5"/>
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="{StaticResource OldGoldBrush}"
                                                       FontSize="14"
                                                       FontWeight="Bold"
                                                       Margin="0,0,0,5"/>
                                            <TextBlock Text="{Binding Summary}"
                                                       Foreground="{StaticResource TextOnDarkBrush}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Right Column: Play Button & Progress -->
            <Border Grid.Column="2"
                    Background="{StaticResource MetallicGrayBrush}"
                    BorderBrush="{StaticResource OldGoldBrush}"
                    BorderThickness="2,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Background Image Placeholder -->
                    <Border Grid.Row="0"
                            Background="{StaticResource PrimaryBlackBrush}">
                        <TextBlock Text="DRAGON BACKGROUND"
                                  Foreground="{StaticResource MediumGrayBrush}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  FontSize="12"
                                  Opacity="0.3"/>
                    </Border>
                    
                    <!-- Play Button -->
                    <Button Grid.Row="0"
                            Content="{Binding ButtonText}"
                            Style="{StaticResource PlayButtonStyle}"
                            Command="{Binding PlayCommand}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Width="300"
                            Height="60"
                            IsEnabled="{Binding IsPlayEnabled}"/>
                    
                    <!-- Progress Bar -->
                    <ProgressBar Grid.Row="1"
                                 Style="{StaticResource ProgressBarStyle}"
                                 Value="{Binding Progress}"
                                 Margin="20,10"/>
                    
                    <!-- Status Text -->
                    <TextBlock Grid.Row="2"
                               Text="{Binding StatusText}"
                               Foreground="{StaticResource TextOnDarkBrush}"
                               HorizontalAlignment="Center"
                               Margin="20,5"
                               FontSize="12"/>
                    
                    <!-- Log Panel -->
                    <Border Grid.Row="3"
                            Style="{StaticResource NewsItemStyle}"
                            MaxHeight="150"
                            Margin="20,10">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <TextBlock Text="{Binding LogText}"
                                       Foreground="{StaticResource OldGoldBrush}"
                                       FontFamily="Consolas"
                                       FontSize="9"
                                       TextWrapping="NoWrap"/>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

