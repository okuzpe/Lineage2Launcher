<Window x:Class="L2TitanLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:L2TitanLauncher.ViewModels"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Launcher l2Titan"
        Height="760"
        Width="1280"
        WindowStyle="None"
        Background="#0D0D12"
        ResizeMode="CanResize">

    <!-- WindowChrome: let the OS manage resize borders + maximize work-area clamping.
         CaptionHeight=0 keeps the existing Header_MouseDown/DragMove drag behavior intact. -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            CaptionHeight="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Triggers>
        <!-- Window Entrance: fade + slide up -->
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.5"/>
                    <DoubleAnimation Storyboard.TargetName="MainBorder"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                     From="24" To="0" Duration="0:0:0.5">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Border x:Name="MainBorder"
            Style="{StaticResource WindowFrameStyle}"
            ClipToBounds="True"
            RenderOptions.BitmapScalingMode="HighQuality">
        <Border.RenderTransform>
            <TranslateTransform Y="0"/>
        </Border.RenderTransform>

        <!-- ROOT GRID: TopBar / Hero / ActionBar -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>    <!-- TopBar -->
                <RowDefinition Height="*"/>     <!-- Hero: background + WebView2 -->
                <RowDefinition Height="96"/>    <!-- ActionBar -->
            </Grid.RowDefinitions>

            <!-- ================================================ -->
            <!-- LAYER 0: BACKGROUND IMAGE (spans all rows)       -->
            <!-- ================================================ -->
            <Grid Grid.Row="0" Grid.RowSpan="3" IsHitTestVisible="False">
                <Image x:Name="BackgroundImage"
                       Source="pack://application:,,,/Assets/images/background.png"
                       Stretch="UniformToFill"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Opacity="0.85">
                    <Image.Style>
                        <Style TargetType="Image">
                            <Style.Triggers>
                                <Trigger Property="Source" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>
                <!-- Top vignette — TopBar readability -->
                <Rectangle VerticalAlignment="Top" Height="80">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#E00D0D12" Offset="0"/>
                            <GradientStop Color="#000D0D12" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <!-- Bottom vignette — ActionBar readability -->
                <Rectangle VerticalAlignment="Bottom" Height="130">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#000D0D12" Offset="0"/>
                            <GradientStop Color="#F50D0D12" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
            </Grid>

            <!-- ================================================ -->
            <!-- ROW 0: TOP BAR                                    -->
            <!-- ================================================ -->
            <Border Grid.Row="0"
                    Style="{StaticResource TopBarStyle}"
                    MouseDown="Header_MouseDown">
                <Grid Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>   <!-- Logo -->
                        <ColumnDefinition Width="*"/>      <!-- Spacer -->
                        <ColumnDefinition Width="Auto"/>   <!-- Links + controls -->
                    </Grid.ColumnDefinitions>

                    <!-- Logo -->
                    <TextBlock Grid.Column="0"
                               Text="Launcher l2Titan"
                               FontFamily="{StaticResource EpicTitleFont}"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource BrightGoldBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,32,0"
                               Style="{StaticResource BaseTextStyle}">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#C9A84C" BlurRadius="8" ShadowDepth="0" Opacity="0.35"/>
                        </TextBlock.Effect>
                    </TextBlock>

                    <!-- Right: Web + Discord + Rates + version + window controls -->
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <!-- Web -->
                        <Border CornerRadius="4" Padding="10,5" Margin="0,0,8,0" Cursor="Hand"
                                Background="#22C9A84C" BorderBrush="{StaticResource SeparatorGoldBrush}" BorderThickness="1">
                            <Border.InputBindings>
                                <MouseBinding Gesture="LeftClick" Command="{Binding OpenSupportCommand}"/>
                            </Border.InputBindings>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#44C9A84C"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="🌐  Website"
                                       FontFamily="{StaticResource UIFont}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrightGoldBrush}"
                                       Style="{StaticResource BaseTextStyle}"/>
                        </Border>

                        <!-- Discord -->
                        <Border CornerRadius="4" Padding="10,5" Margin="0,0,8,0" Cursor="Hand"
                                Background="#225865F4" BorderBrush="#335865F4" BorderThickness="1">
                            <Border.InputBindings>
                                <MouseBinding Gesture="LeftClick" Command="{Binding OpenDiscordCommand}"/>
                            </Border.InputBindings>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#445865F4"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="💬  Discord"
                                       FontFamily="{StaticResource UIFont}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#A5B4FC"
                                       Style="{StaticResource BaseTextStyle}"/>
                        </Border>

                        <!-- TikTok -->
                        <Border CornerRadius="4" Padding="10,5" Margin="0,0,20,0" Cursor="Hand"
                                Background="#22FE2C55" BorderBrush="#33FE2C55" BorderThickness="1">
                            <Border.InputBindings>
                                <MouseBinding Gesture="LeftClick" Command="{Binding OpenTikTokCommand}"/>
                            </Border.InputBindings>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#44FE2C55"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="🎵  TikTok"
                                       FontFamily="{StaticResource UIFont}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#FDA4AF"
                                       Style="{StaticResource BaseTextStyle}"/>
                        </Border>

                        <!-- Version -->
                        <TextBlock Text="{Binding VersionText}"
                                   FontFamily="{StaticResource UIFont}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,16,0"
                                   Style="{StaticResource BaseTextStyle}"/>

                        <!-- Separator -->
                        <Border Width="1" Height="16"
                                Background="{StaticResource SeparatorGoldBrush}"
                                VerticalAlignment="Center"
                                Margin="0,0,12,0"/>

                        <!-- Minimize -->
                        <Button x:Name="MinimizeButton"
                                Content="─"
                                Style="{StaticResource WindowControlButtonStyle}"
                                Click="MinimizeButton_Click"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                Width="32" Height="32"
                                Margin="0,0,4,0"/>
                        <!-- Maximize / Restore -->
                        <Button x:Name="MaximizeButton"
                                Content="▢"
                                Style="{StaticResource WindowControlButtonStyle}"
                                Click="MaximizeButton_Click"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                Width="32" Height="32"
                                Margin="0,0,4,0"/>
                        <!-- Close -->
                        <Button x:Name="CloseButton"
                                Content="✕"
                                Style="{StaticResource WindowControlButtonStyle}"
                                Click="CloseButton_Click"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                Width="32" Height="32"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ================================================ -->
            <!-- ROW 1: HERO — WebView2                           -->
            <!-- ================================================ -->
            <Grid Grid.Row="1">
                <!-- WebView2 embedded browser. Source is set in code-behind AFTER
                     EnsureCoreWebView2Async so the custom userDataFolder environment is honored. -->
                <wv2:WebView2 x:Name="LauncherWebView"
                              Visibility="Collapsed"/>

                <!-- Fallback: shown if WebView2 runtime not available -->
                <Border x:Name="WebViewFallback"
                        Background="#110D0D12"
                        Visibility="Visible">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="🌐"
                                   FontSize="48"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,16"
                                   Style="{StaticResource BaseTextStyle}"/>
                        <TextBlock x:Name="FallbackMessage"
                                   Text="Loading content..."
                                   FontFamily="{StaticResource UIFont}"
                                   FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   Style="{StaticResource BaseTextStyle}"/>
                        <TextBlock Text="Visit l2-titan.com"
                                   FontFamily="{StaticResource UIFont}"
                                   FontSize="12"
                                   Foreground="{StaticResource SeparatorGoldBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0"
                                   Style="{StaticResource BaseTextStyle}">
                            <TextBlock.InputBindings>
                                <MouseBinding Gesture="LeftClick" Command="{Binding OpenSupportCommand}"/>
                            </TextBlock.InputBindings>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ================================================ -->
            <!-- ROW 2: ACTION BAR                                 -->
            <!-- ================================================ -->
            <Border Grid.Row="2" Style="{StaticResource ActionBarStyle}">
                <Grid Margin="40,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>     <!-- Progress + status -->
                        <ColumnDefinition Width="180"/>   <!-- Play button -->
                    </Grid.ColumnDefinitions>

                    <!-- Left: Status text + Progress bar -->
                    <StackPanel Grid.Column="0"
                                VerticalAlignment="Center"
                                Margin="0,0,36,0">
                        <TextBlock Text="{Binding StatusText}"
                                   FontFamily="{StaticResource UIFont}"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,8"
                                   Style="{StaticResource BaseTextStyle}"/>
                        <ProgressBar Style="{StaticResource ModernProgressBarStyle}"
                                     Value="{Binding Progress}"/>
                    </StackPanel>

                    <!-- Right: Play button -->
                    <Button Grid.Column="1"
                            Content="{Binding ButtonText}"
                            Style="{StaticResource ModernPlayButtonStyle}"
                            Command="{Binding PlayCommand}"
                            IsEnabled="{Binding IsPlayEnabled}"
                            Background="{Binding ButtonBackgroundBrush, UpdateSourceTrigger=PropertyChanged}"
                            BorderBrush="{Binding ButtonBorderBrush, UpdateSourceTrigger=PropertyChanged}"
                            Foreground="{Binding ButtonForegroundBrush, UpdateSourceTrigger=PropertyChanged}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
