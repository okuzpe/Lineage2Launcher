<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ================================================ -->
    <!-- BASE STYLES                                       -->
    <!-- ================================================ -->

    <!-- Base TextBlock Style - ClearType rendering -->
    <Style x:Key="BaseTextStyle" TargetType="TextBlock">
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="RenderOptions.ClearTypeHint" Value="Enabled"/>
        <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality"/>
    </Style>

    <!-- Gold Label Style -->
    <Style x:Key="GoldLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource BaseTextStyle}">
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Gold Value Style -->
    <Style x:Key="GoldValueStyle" TargetType="TextBlock" BasedOn="{StaticResource BaseTextStyle}">
        <Setter Property="Foreground" Value="{StaticResource BrightGoldBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="5,0,0,0"/>
    </Style>

    <!-- Footer / Nav Link Style -->
    <Style x:Key="FooterLinkStyle" TargetType="TextBlock" BasedOn="{StaticResource BaseTextStyle}">
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{StaticResource BrightGoldBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Rate Item DataTemplate -->
    <DataTemplate x:Key="RateItemTemplate">
        <StackPanel>
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Name}" Style="{StaticResource GoldLabelStyle}"/>
                <TextBlock Grid.Column="1" Text="{Binding Value, StringFormat='x{0}'}" Style="{StaticResource GoldValueStyle}"/>
            </Grid>
            <Border Height="1" Margin="0,3,0,3" Background="{StaticResource SeparatorGoldBrush}"/>
        </StackPanel>
    </DataTemplate>

    <!-- ================================================ -->
    <!-- WINDOW FRAME                                      -->
    <!-- ================================================ -->

    <Style x:Key="WindowFrameStyle" TargetType="Border">
        <Setter Property="BorderBrush" Value="{StaticResource SeparatorGoldBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="{StaticResource PrimaryBlackBrush}"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#000000"
                                  BlurRadius="20"
                                  ShadowDepth="0"
                                  Opacity="0.9"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ================================================ -->
    <!-- TOP BAR                                           -->
    <!-- ================================================ -->

    <Style x:Key="TopBarStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource TopBarBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SeparatorGoldBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Height" Value="56"/>
    </Style>

    <!-- Tab Button Base (sin estado activo) -->
    <Style x:Key="TabButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontFamily" Value="{StaticResource EpicSubtitleFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="4,0,4,8"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <ContentPresenter x:Name="Content"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                        <!-- Underline indicator (hidden by default) -->
                        <Border x:Name="Underline"
                                Height="2"
                                VerticalAlignment="Bottom"
                                HorizontalAlignment="Stretch"
                                Background="{StaticResource BrightGoldBrush}"
                                Opacity="0"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource BrightGoldBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Tab activo: foreground dorado + underline visible -->
    <Style x:Key="ActiveTabButtonStyle" TargetType="Button" BasedOn="{StaticResource TabButtonStyle}">
        <Setter Property="Foreground" Value="{StaticResource BrightGoldBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <ContentPresenter x:Name="Content"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                        <Border x:Name="Underline"
                                Height="2"
                                VerticalAlignment="Bottom"
                                HorizontalAlignment="Stretch"
                                Background="{StaticResource BrightGoldBrush}"
                                Opacity="1"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource AccentGoldHighBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Window Control Buttons (minimal flat) -->
    <Style x:Key="WindowControlButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#22FFFFFF"/>
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#44FFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ================================================ -->
    <!-- GLASS CARDS                                       -->
    <!-- ================================================ -->

    <Style x:Key="GlassCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource GlassCardBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SeparatorGoldBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="0" Opacity="0.6"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- News Featured Card -->
    <Style x:Key="NewsFeaturedCardStyle" TargetType="Border" BasedOn="{StaticResource GlassCardStyle}">
        <Setter Property="Width" Value="390"/>
        <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <!-- Server Status Pill -->
    <Style x:Key="ServerStatusPillStyle" TargetType="Border">
        <Setter Property="Background" Value="#CC0D0D12"/>
        <Setter Property="BorderBrush" Value="{StaticResource SeparatorGoldBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#000000" BlurRadius="16" ShadowDepth="0" Opacity="0.5"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ================================================ -->
    <!-- ACTION BAR                                        -->
    <!-- ================================================ -->

    <Style x:Key="ActionBarStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ActionBarBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SeparatorGoldBrush}"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
        <Setter Property="Height" Value="96"/>
    </Style>

    <!-- ================================================ -->
    <!-- SLIDE PANEL (Tasas)                               -->
    <!-- ================================================ -->

    <Style x:Key="SlidePanelStyle" TargetType="Border">
        <Setter Property="Width" Value="280"/>
        <Setter Property="Background" Value="#F00D0D12"/>
        <Setter Property="BorderBrush" Value="{StaticResource SeparatorGoldBrush}"/>
        <Setter Property="BorderThickness" Value="1,0,0,0"/>
    </Style>

    <!-- ================================================ -->
    <!-- MODERN PLAY BUTTON                                -->
    <!-- ================================================ -->

    <Style x:Key="ModernPlayButtonStyle" TargetType="Button">
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="FontFamily" Value="{StaticResource EpicTitleFont}"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Height" Value="52"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="RenderOptions.ClearTypeHint" Value="Enabled"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="OuterBorder"
                                Background="{Binding Background, RelativeSource={RelativeSource TemplatedParent}}"
                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource TemplatedParent}}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                            <!-- Top Gloss subtle -->
                            <Grid>
                                <Rectangle x:Name="TopGloss"
                                           Height="6"
                                           VerticalAlignment="Top"
                                           Opacity="0.15"
                                           RadiusX="6" RadiusY="6">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Content="{TemplateBinding Content}"
                                                  TextElement.Foreground="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"
                                                  TextOptions.TextFormattingMode="Ideal"
                                                  TextOptions.TextRenderingMode="ClearType"
                                                  UseLayoutRounding="True"
                                                  RenderOptions.ClearTypeHint="Enabled"/>
                            </Grid>
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="2" Opacity="0.4" Direction="270"/>
                            </Border.Effect>
                        </Border>

                        <!-- Glow Layer -->
                        <Border x:Name="GlowLayer"
                                CornerRadius="6"
                                BorderThickness="0"
                                Background="Transparent"
                                Opacity="0"
                                IsHitTestVisible="False">
                            <Border.Effect>
                                <DropShadowEffect Color="{StaticResource OldGold}"
                                                  BlurRadius="18"
                                                  ShadowDepth="0"
                                                  Opacity="1.0"/>
                            </Border.Effect>
                        </Border>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!-- Ready State: preserve VM-provided brushes -->
                        <DataTrigger Binding="{Binding IsReady, UpdateSourceTrigger=PropertyChanged}" Value="True">
                            <Setter TargetName="OuterBorder" Property="Opacity" Value="1.0"/>
                            <Setter TargetName="OuterBorder" Property="Background" Value="{Binding Background, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{Binding BorderBrush, RelativeSource={RelativeSource TemplatedParent}}"/>
                        </DataTrigger>

                        <!-- Ready Pulse Animation -->
                        <DataTrigger Binding="{Binding IsReady, UpdateSourceTrigger=PropertyChanged}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard x:Name="ReadyPulse">
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <DoubleAnimation Storyboard.TargetName="GlowLayer"
                                                         Storyboard.TargetProperty="Opacity"
                                                         From="0.25" To="0.75" Duration="0:0:1.5">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="ReadyPulse"/>
                            </DataTrigger.ExitActions>
                        </DataTrigger>

                        <!-- Hover -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="OuterBorder"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="1.03" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="OuterBorder"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="1.03" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="GlowLayer"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="OuterBorder"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="1.0" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="OuterBorder"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="1.0" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="GlowLayer"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>

                        <!-- Pressed -->
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="OuterBorder"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="0.98" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="OuterBorder"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="0.98" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="GlowLayer"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.4" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="OuterBorder"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="1.0" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="OuterBorder"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="1.0" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>

                        <!-- Press: darken overlay via Opacity -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="OuterBorder" Property="Opacity" Value="0.72"/>
                        </Trigger>

                        <!-- IsEnabled=False (Checking): let VM brush show, just dim slightly -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="OuterBorder" Property="Opacity" Value="0.85"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ================================================ -->
    <!-- MODERN PROGRESS BAR                               -->
    <!-- ================================================ -->

    <Style x:Key="ModernProgressBarStyle" TargetType="ProgressBar">
        <Setter Property="Background" Value="#22FFFFFF"/>
        <Setter Property="Foreground" Value="{StaticResource ProgressFillGradientBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Height" Value="6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderThickness="0"
                            CornerRadius="3">
                        <Grid>
                            <Rectangle x:Name="PART_Track" Fill="{TemplateBinding Background}" RadiusX="3" RadiusY="3"/>
                            <Rectangle x:Name="PART_Indicator"
                                       Fill="{TemplateBinding Foreground}"
                                       HorizontalAlignment="Left"
                                       RadiusX="3" RadiusY="3">
                                <Rectangle.Effect>
                                    <DropShadowEffect Color="{StaticResource BrightGold}"
                                                      BlurRadius="6"
                                                      ShadowDepth="0"
                                                      Opacity="0.7"/>
                                </Rectangle.Effect>
                            </Rectangle>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Progress Shimmer (legacy compat) -->
    <Storyboard x:Key="ProgressShimmerAnimation" RepeatBehavior="Forever">
        <DoubleAnimation Storyboard.TargetProperty="(Rectangle.Fill).(LinearGradientBrush.Transform).(TranslateTransform.X)"
                         From="-200" To="200" Duration="0:0:1.2"/>
    </Storyboard>

    <!-- ================================================ -->
    <!-- LEGACY STYLES (kept for compat, not used in UI)  -->
    <!-- ================================================ -->

    <Style x:Key="PlayButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernPlayButtonStyle}"/>

    <Style x:Key="ProgressBarStyle" TargetType="ProgressBar" BasedOn="{StaticResource ModernProgressBarStyle}"/>

    <Style x:Key="ServerItemStyle" TargetType="Border" BasedOn="{StaticResource GlassCardStyle}"/>

    <Style x:Key="NewsItemStyle" TargetType="Border" BasedOn="{StaticResource GlassCardStyle}"/>

    <Style x:Key="GoldBorderStyle" TargetType="Border">
        <Setter Property="BorderBrush" Value="{StaticResource GoldGradientBrush}"/>
    </Style>

    <Style x:Key="GoldBorderTexturedStyle" TargetType="Border" BasedOn="{StaticResource GoldBorderStyle}"/>

</ResourceDictionary>
