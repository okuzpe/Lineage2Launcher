                                <DropShadowEffect Color="#000000" BlurRadius="0.5" ShadowDepth="0" Opacity="0.2"/>
                            </TextBlock.Effect>
                            <TextBlock.InputBindings>
                                <MouseBinding Gesture="LeftClick" Command="{Binding OpenSupportCommand}"/>
                            </TextBlock.InputBindings>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource BrightGoldBrush}"/>
                                            <Setter Property="Opacity" Value="0.8"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        
                        <!-- Decorative separator -->
                        <Border Width="1" Height="14" Background="{StaticResource OldGoldBrush}" Opacity="0.3" Margin="0,0,25,0"/>
                        
                        <TextBlock Text="Forum"
                                   Foreground="{StaticResource BrightGoldBrush}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Cursor="Hand"
                                   Margin="0,0,25,0"
                                   TextOptions.TextFormattingMode="Ideal"
                                   TextOptions.TextRenderingMode="ClearType"
                                   UseLayoutRounding="True"
                                   RenderOptions.ClearTypeHint="Enabled"
                                   RenderOptions.BitmapScalingMode="HighQuality">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="0.5" ShadowDepth="0" Opacity="0.2"/>
                            </TextBlock.Effect>
                            <TextBlock.InputBindings>
                                <MouseBinding Gesture="LeftClick" Command="{Binding OpenForumCommand}"/>
                            </TextBlock.InputBindings>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource BrightGoldBrush}"/>
                                            <Setter Property="Opacity" Value="0.8"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        
                        <!-- Decorative separator -->
                        <Border Width="1" Height="14" Background="{StaticResource OldGoldBrush}" Opacity="0.3" Margin="0,0,25,0"/>
                        
                        <TextBlock Text="Discord"
                                   Foreground="{StaticResource BrightGoldBrush}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Cursor="Hand"
                                   TextOptions.TextFormattingMode="Ideal"
                                   TextOptions.TextRenderingMode="ClearType"
                                   UseLayoutRounding="True"
                                   RenderOptions.ClearTypeHint="Enabled"
                                   RenderOptions.BitmapScalingMode="HighQuality">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="0.5" ShadowDepth="0" Opacity="0.2"/>
                            </TextBlock.Effect>
                            <TextBlock.InputBindings>
                                <MouseBinding Gesture="LeftClick" Command="{Binding OpenDiscordCommand}"/>
                            </TextBlock.InputBindings>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource BrightGoldBrush}"/>
                                            <Setter Property="Opacity" Value="0.8"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
